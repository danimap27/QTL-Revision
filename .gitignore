.env
.env.local
.env.*.local
config.ini
secrets.json

# Datos y modelos entrenados
model_saved/
*.pth
*.pkl
*.joblib

# Gráficas y métricas
static/metrics/
plots/
# Excluir imágenes de métricas y gráficas, pero permitir datasets
static/**/*.png
static/**/*.jpg
static/**/*.jpeg
static/**/*.svg
experiment_results/**/*.png
experiment_results/**/*.jpg
Resultados/**/*.png
Resultados/**/*.jpg
# Permitir explícitamente imágenes en datasets
!datasets/**/*.png
!datasets/**/*.jpg
!datasets/**/*.jpeg
!datasets/**/*.gif

# Datasets grandes - permitir estructura y archivos pequeños
# Excluir solo archivos muy grandes (>100MB)
datasets/**/*.zip
datasets/**/*.tar.gz
datasets/**/*.rar
# Permitir archivos de menos de 100MB
!datasets/README.md
!datasets/*/README.md
# Permitir estructura de directorios y archivos pequeños de ejemplo
!datasets/*/
!datasets/*/*/
!datasets/*/*/*/

# Logs y archivos temporales
*.log
*.tmp
temp/
tmp/

# Archivos de resultados experimentales (mantener estructura básica)
experiment_results/
results/
outputs/
runs/

# Directorio Resultados (copia duplicada)
Resultados/datasets/
Resultados/experiment_results/
Resultados/__pycache__/
Resultados/*.png
Resultados/*.jpg

# Cachés de ML/DL frameworks
.wandb/
mlruns/
lightning_logs/

